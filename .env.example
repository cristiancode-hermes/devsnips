# DevSnips - Environment Variables
# Copy this to .env and fill in your values

# Neon Database (get from Neon Console > Project > Connection Details)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-your-host.eu-west-2.aws.neon.tech/neondb?sslmode=require
NEON_PROJECT_ID=your-project-id
NEON_HOST=ep-your-host.eu-west-2.aws.neon.tech
